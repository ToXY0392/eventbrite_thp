<section class="comments-organism mt-4">
  <h3 class="h5 mb-3"><%= t("app.comments.title") %> (<%= event.comments.count %>)</h3>

  <% if event.comments.any? %>
    <div class="comments-list mb-4 rounded border">
      <% event.comments.order(created_at: :asc).each do |comment| %>
        <%= render "comments/comment", comment: comment %>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted mb-4"><%= t("app.comments.empty") %></p>
  <% end %>

  <% if user_signed_in? %>
    <%= form_with model: [event, Comment.new], url: event_comments_path(event), class: "mt-3" do |f| %>
      <div class="mb-2">
        <%= f.text_area :content, rows: 3, class: "form-control", placeholder: t("app.comments.placeholder") %>
        <%= f.object&.errors&.full_messages_for(:content)&.first %>
      </div>
      <%= f.submit t("app.comments.submit"), class: "btn btn-primary" %>
    <% end %>
  <% else %>
    <p class="text-muted small"><%= link_to t("app.nav.sign_in"), new_user_session_path %> <%= t("app.comments.sign_in_to_comment") %></p>
  <% end %>
</section>
