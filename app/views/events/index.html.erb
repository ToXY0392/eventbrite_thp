<% content_for :skip_container do %><% end %>

<%= render "shared/hero_index" %>

<%= render "shared/testimonial",
           quote: t("app.events.index.testimonial_quote"),
           author: t("app.events.index.testimonial_author") %>

<%= render "shared/feature_block",
           title: t("app.events.index.feature_create_title"),
           text: t("app.events.index.feature_create_text"),
           image_left: false,
           cta_text: t("app.events.index.feature_cta_create"),
           cta_path: new_event_path %>

<%= render "shared/cities_section", cities: @cities %>

<%= render "events/events_list", events: @events, location_filter: params[:location] %>
