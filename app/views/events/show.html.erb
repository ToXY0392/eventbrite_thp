<%= render "shared/banner_small", title: @event.title, image: (@event.picture.attached? ? @event.picture : nil), subtitle: @event.location %>

<div class="row">
  <!-- Col 8 : Image + description -->
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm mb-4">
      <% if @event.picture.attached? %>
        <%= image_tag @event.picture, class: "card-img-top", alt: @event.title, style: "max-height: 400px; object-fit: cover;" %>
      <% else %>
        <div class="card-img-placeholder card-img-top d-flex align-items-center justify-content-center" style="height: 200px; background: var(--bs-secondary-bg);">
          <span class="text-muted fs-1"><%= @event.title.to_s[0, 2].upcase %></span>
        </div>
      <% end %>
      <div class="card-body">
        <h1 class="h2 mb-3"><%= @event.title %></h1>
        <div class="mb-0">
          <%= simple_format(@event.description, class: "mb-0") %>
        </div>
        <%= render "events/event_admin_buttons", event: @event %>
      </div>
    </div>

    <!-- Section commentaires -->
    <%= render "comments/comments_section", event: @event %>
  </div>

  <!-- Col 4 : Infos + Rejoindre -->
  <div class="col-lg-4">
    <div class="card border-0 shadow-sm mb-4 sticky-top">
      <div class="card-body">
        <%= render "events/event_details", event: @event %>

        <hr class="my-3">

        <% if user_signed_in? %>
          <% if current_user == @event.admin %>
            <%= link_to t("app.events.show.admin_space"), event_attendances_path(@event), class: "btn btn-primary w-100 mb-2" %>
          <% elsif @event.participants.include?(current_user) %>
            <p class="text-muted mb-2"><%= t("app.events.show.already_joined") %></p>
          <% else %>
            <% if @event.is_free? %>
              <%= button_to t("app.events.show.join_btn"),
                            event_attendances_path(@event),
                            method: :post,
                            class: "btn btn-success w-100 mb-2" %>
            <% else %>
              <%= link_to t("app.events.show.join_btn"),
                          new_event_attendance_path(@event),
                          class: "btn btn-success w-100 mb-2" %>
            <% end %>
          <% end %>
        <% else %>
          <p class="text-muted small mb-2">
            <%= link_to t("app.nav.sign_in"), new_user_session_path %> <%= t("app.events.show.sign_in_to_join") %>
          </p>
        <% end %>

        <%= link_to t("app.events.show.back"), root_path, class: "btn btn-outline-secondary w-100" %>
      </div>
    </div>
  </div>
</div>
