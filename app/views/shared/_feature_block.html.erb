<%
  title = local_assigns[:title] || "Titre"
  text = local_assigns[:text] || ""
  image_src = local_assigns[:image]
  image_left = local_assigns.fetch(:image_left, true)
  cta_text = local_assigns[:cta_text]
  cta_path = local_assigns[:cta_path]
%>
<section class="feature-block py-5 <%= image_left ? '' : 'feature-block-reverse' %>">
  <div class="container">
    <div class="row align-items-center g-4">
      <div class="col-lg-6 <%= image_left ? 'order-lg-1' : 'order-lg-2' %>">
        <% if image_src.present? %>
          <%= image_tag image_src, class: "img-fluid rounded-3 shadow-sm", alt: title %>
        <% else %>
          <div class="feature-placeholder rounded-3 d-flex align-items-center justify-content-center bg-primary bg-opacity-10" style="min-height: 280px;">
            <span class="display-1 text-primary opacity-50">📅</span>
          </div>
        <% end %>
      </div>
      <div class="col-lg-6 <%= image_left ? 'order-lg-2' : 'order-lg-1' %>">
        <h2 class="h3 fw-bold mb-3"><%= title %></h2>
        <p class="text-muted mb-4"><%= text %></p>
        <% if cta_text.present? && cta_path.present? %>
          <%= link_to cta_text, cta_path, class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</section>
