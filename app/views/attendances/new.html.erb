<div class="row">
  <div class="col-md-8 offset-md-2">
    <h1 class="h3 mb-4"><%= t("app.attendances.new.title") %></h1>

    <%= render "attendances/event_summary_card", event: @event %>

    <%= button_to t("app.attendances.new.pay_btn"),
                  event_attendance_checkout_path(@event),
                  method: :post,
                  data: { turbo: false },
                  class: "btn btn-success btn-lg" %>

    <%= link_to t("app.events.show.back"), @event, class: "btn btn-outline-secondary mt-3" %>
  </div>
</div>
